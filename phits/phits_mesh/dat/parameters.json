{
    
    // ---------------------------------------------- //
    // ---  Simulation Control Settings          ---- //
    // ---------------------------------------------- //
    //
    "sim.icntl"          :     0,    // ( 0:transport, 6:check-source, 8:check-Geometry )
    "sim.istdev"         :     2,    // ( 0:optimal  , 1:batch-stddev, 2:history-stddev ) ( +:New, -:Continue )
    "sim.parallel.type"  : "MPI",    // "MPI" / "OMP"
    "sim.parallel.nProc" :     4,
    "sim.nParticle"      : 1.0e7,    // preferably  nProc * xxx
    "sim.nBatch"         : "@sim.parallel.nProc*50",
    "sim.nCascade"       : "@sim.nParticle/@sim.nBatch",
    "sim.phits_output"   : "out/phits.out",

    // --- level7 & galleria --- //    ( 133.144.160.74 & 133.144.160.131 )
    // "sim.phits_directory": "/common1/hpclocal/PHITS/phits321/phits/",
    // "sim.phits_xsdir"    : "/home/users/70727338/Lib80x/xsdir.jnd",
    
    // "sim.phits_directory": "/mnt/c/phits/build_phits328A/phits/",
    // "sim.phits_xsdir"    : "/mnt/c/phits/build_phits328A/phits/data/xsdir.jnd",
    
    // ---     rdhpc1        --- //    ( 10.225.216.10   )
    // "sim.phits_directory": "/common1/hpclocal/PHITS/phits321/phits/",
    // "sim.phits_xsdir"    : "/home/users/70727338/Lib80x/xsdir.jnd",

    // ---      nec          --- //  
    "sim.phits_directory"        : "/mnt/c/opt/phits328A/phits/",
    "sim.phits_xsdir"            : "/mnt/c/opt/phits328A/phits/data/xsdir.jnd",

    // ---------------------------------------------- //
    // ---  Constants  Settings                  ---- //
    // ---------------------------------------------- //    
    "mm"                 : 0.1,
    "m2cm"               : 100.0,
    "pi"                 : 3.14159265358,
    "ln2"                : 0.69314718056,
    "NAvogadro"          : 6.02e23,

    // ---------------------------------------------- //
    // ---  convertor Settings                   ---- //
    // ---------------------------------------------- //
    "converter.matNum"   : "@Ta.matNum",
    "converter.density"  : "@Ta.density",
    
    // ---------------------------------------------- //
    // ---  source part  :: beam settings        ---- //
    // ---------------------------------------------- //
    "beam.type"          : "gaussian",                  // [ "gaussian", "pencil", "emittance" ]
    "beam.energy"        :     40.0,
    "beam.energy.FWHM.%" :      5.0,
    "beam.current"       : 100.0e-6,
    "beam.FWHM"          : "  6.00 * @mm",
    "beam.zStart"        : "-200.0 * @mm",
    "beam.length"        : "  10.0 * @mm",

    "beam.totfact"       : "@beam.current / 1.602e-19", // -- unit :: [ particles / s ] -- //
    // "beam.HWHM"          : "0.5 * @beam.FWHM",
    "beam.zEnd"          : "@beam.zStart - @beam.length",
    "beam.energy.FWHM.MeV"      : "@beam.energy * @beam.energy.FWHM.%/100.0",
    "beam.energy.cutoff.lower"  : "@beam.energy - @beam.energy.FWHM.MeV/2.35*3", 
    "beam.energy.cutoff.upper"  : "@beam.energy + @beam.energy.FWHM.MeV/2.35*3", 
    
    // ---------------------------------------------- //
    // ---  geometry part ::                     ---- //
    // ---------------------------------------------- //

    "geometry.meshFile" : "msh/model",
    
    // ---------------- //
    //   unit :: mm  -- //
    // ---------------- //
    "bb.buff"           :  10.0,
    "bb.mesh.mm.xMin"   : -50.0,  // actual (xMin,xMax) of CAD or Mesh.
    "bb.mesh.mm.xMax"   : +50.0,
    "bb.mesh.mm.yMin"   : -50.0,
    "bb.mesh.mm.yMax"   : +50.0,
    "bb.mesh.mm.zMin"   : -21.15,
    "bb.mesh.mm.zMax"   : +34.25,

    "bb.fill.xMin"      : "@bb.mesh.mm.xMin * @mm",   // 
    "bb.fill.xMax"      : "@bb.mesh.mm.xMax * @mm",
    "bb.fill.yMin"      : "@bb.mesh.mm.yMin * @mm",
    "bb.fill.yMax"      : "@bb.mesh.mm.yMax * @mm",
    "bb.fill.zMin"      : "@bb.mesh.mm.zMin * @mm",
    "bb.fill.zMax"      : "@bb.mesh.mm.zMax * @mm",
    // univ > fill
    "bb.univ.xMin"      : "( @bb.mesh.mm.xMin - @bb.buff ) * @mm",
    "bb.univ.xMax"      : "( @bb.mesh.mm.xMax + @bb.buff ) * @mm",
    "bb.univ.yMin"      : "( @bb.mesh.mm.yMin - @bb.buff ) * @mm",
    "bb.univ.yMax"      : "( @bb.mesh.mm.yMax + @bb.buff ) * @mm",
    "bb.univ.zMin"      : "( @bb.mesh.mm.zMin - @bb.buff ) * @mm",
    "bb.univ.zMax"      : "( @bb.mesh.mm.zMax + @bb.buff ) * @mm",

    "bb.phits.mm.xMin"  : -300.0,
    "bb.phits.mm.xMax"  : +300.0,
    "bb.phits.mm.yMin"  : -300.0,
    "bb.phits.mm.yMax"  : +300.0,
    "bb.phits.mm.zMin"  : -300.0,
    "bb.phits.mm.zMax"  : +300.0,

    "bb.phits.xMin"     : "@bb.phits.mm.xMin * @mm",
    "bb.phits.xMax"     : "@bb.phits.mm.xMax * @mm",
    "bb.phits.yMin"     : "@bb.phits.mm.yMin * @mm",
    "bb.phits.yMax"     : "@bb.phits.mm.yMax * @mm",
    "bb.phits.zMin"     : "@bb.phits.mm.zMin * @mm",
    "bb.phits.zMax"     : "@bb.phits.mm.zMax * @mm",


    // --------------------------- //
    // -- buffer air / bb       -- //
    // --------------------------- //
    "buff.margin"            : "50.0 * @mm",
    "buff.rpp"               : [ "@lyr.xMin     -@buff.margin", "@lyr.xMax     +@buff.margin",
                                 "@lyr.yMin     -@buff.margin", "@lyr.yMax     +@buff.margin",
                                 "@lyr.01.rpp[4]-@buff.margin", "@lyr.16.rpp[5]+@buff.margin", ],
    "bb.rpp"                 : [ "-500.0*@mm", "+500.0*@mm",
                                 "-500.0*@mm", "+500.0*@mm",
                                 "-500.0*@mm", "+500.0*@mm", ], 

    "closeup.margin"         : "10.0 * @mm", 
    "closeup.rpp"            : [ "-20*@mm", "20*@mm", "-20*@mm", "20*@mm",
                                 "@lyr.05.rpp[4]-@closeup.margin",
                                 "@lyr.16.rpp[5]+@closeup.margin", ],


    // ---------------------------------------------- //
    // ---  tally part       :: tally settings   ---- //
    // ---------------------------------------------- //
    "tally.fluence-g-energy.sw" : true,
    "tally.fluence-g-xz.sw"     : true,
    "tally.geometry-xz.sw"      : true,
    "tally.fluence-n-energy.sw" : true,
    "tally.fluence-n-xz.sw"     : true,


    
}
