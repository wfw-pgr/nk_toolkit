
{% if prm["tally.fluence-g-energy.sw"] %}
$$ ---------------------------------------------------------- $$
$$ --- tally for fluence - energy for RIprodReaction       ---$$
$$ ---------------------------------------------------------- $$
[T-Track]
   mesh =  reg
    reg =  101          $$ target region number ::
    volume
     reg     vol
     101     1.0        $$ vol=1.0 => count mode.
 e-type =    2
     ne =  100
   emin =  0.0
   emax =  50.0
 material = 10
 5001 5002 5003 5004 5005 5006 5007 5008 5009 5010
   part =  photon
   unit =    2           $$ unit is [1/cm^2/MeV/source]
   axis =  eng
   file =  out/fluence-g-energy.dat
  x-txt =  energy [MeV]
  y-txt =  track length [photons m/MeV/s]
 epsout =    1
{% endif %}


{% if ( prm["sim.icntl"] == 8 ) and ( prm["tally.geometry-xz.sw"] ) %}
$$ ---------------------------------------------------------- $$
$$ --- tally for geometry check ( target region )          ---$$
$$ ---------------------------------------------------------- $$
[T-Track]
   mesh =  xyz          $$ mesh    :: [ xyz, r-z, reg, tet ]
 x-type =    2          $$ x-type  :: [ 1: (nx,data[nx+1]), 2:(nx,xmin,xmax), 3:logarithmic ]
     nx =   600
   xmin =  {{prm["buff.rpp"][0]}}
   xmax =  {{prm["buff.rpp"][1]}}
 y-type =    2
     ny =    1
   ymin =  {{prm["buff.rpp"][2]}}
   ymax =  {{prm["buff.rpp"][3]}}
 z-type =    2
     nz =  1000
   zmin =  {{prm["buff.rpp"][4]}}
   zmax =  {{prm["buff.rpp"][5]}}
 e-type =    2
     ne =    1
   emin =  0.0
   emax =  1.0e3
   unit =    1
   axis =   xz
   file =  out/geometry-xz.dat
  title =  geometry of target region
  gshow =    1
 epsout =    1
{% endif %}




