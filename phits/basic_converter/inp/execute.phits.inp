$$ ----------------------------------------------------------------- $$
$$ ---                     Material Section                      --- $$
$$ ----------------------------------------------------------------- $$

[Material]


$$ ----------------------------------------------------------------- $$
$$ ---                     matNum[1] :: H2O                      --- $$
$$ ----------------------------------------------------------------- $$

mat[1]
    H           2.00000e+00
    O           1.00000e+00


$$ ----------------------------------------------------------------- $$
$$ ---                    matNum[2] :: RaCl2                     --- $$
$$ ----------------------------------------------------------------- $$

mat[2]
    226Ra       1.00000e+00
    Cl          2.00000e+00


$$ ----------------------------------------------------------------- $$
