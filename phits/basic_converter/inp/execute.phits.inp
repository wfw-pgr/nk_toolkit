    P          -2.25000e-04
    Ni         -1.20000e-01
    Cr         -1.70000e-01
    Mo         -2.50000e-02



$$ ----------------------------------------------------------------- $$
$$ ---               matNameColor section (PHITS)                --- $$
$$ ----------------------------------------------------------------- $$

[MatNameColor]
    mat  name               size       color               
    1    H2O                2.0        cyanblue            
    2    RaCl2              2.0        violet              
    3    Ta                 2.0        purple              
    4    He                 2.0        pastelcyan          
    5    Air                2.0        cyan                
    6    Au                 2.0        red                 
    7    Pt                 2.0        purple              
    8    SiO2               2.0        blue                
    9    Ti                 2.0        darkred             
    10   SUS316             2.0        red                 




$$ ---------------------------------------------------------- $$
$$ --- tally for fluence - energy for RIprodReaction       ---$$
$$ ---------------------------------------------------------- $$
[T-Track]
   mesh =  reg
    reg =  345          $$ target region number ::
    volume
     reg     vol
     345     1.0        $$ vol=1.0 => count mode.
 e-type =    2
     ne =  100
   emin =  0.0
   emax =  50.0
   part =  photon
   unit =    2           $$ unit is [1/cm^2/MeV/source]
   axis =  eng
   file =  out/fluence_g_energy.dat
  x-txt =  energy [MeV]
  y-txt =  track length [photons m/MeV/s]
 epsout =    1




$$ ---------------------------------------------------------- $$
$$ --- tally for fluence x-z (2d)                         --- $$
$$ ---------------------------------------------------------- $$
[T-Track]
   mesh =  xyz          $$ mesh    :: [ xyz, r-z, reg, tet ]
 x-type =    2          $$ x-type  :: [ 1: (nx,data[nx+1]), 2:(nx,xmin,xmax), 3:logarithmic ]
     nx =   100
   xmin =  -2.0   $$ "buff.rpp" or "closeup.rpp"
   xmax =  2.0
 y-type =    2
     ny =    1
   ymin =  -2.0
   ymax =  2.0
 z-type =    2
     nz =   100
   zmin =  -1.8
   zmax =  4.06
 e-type =    2
     ne =    1
   emin =  0.0
   emax =  1.0e3
   axis =   xz
   part =  photon
   file =  out/fluence-g-xz.dat
  title =  fluence in xz plane
  gshow =    1
 epsout =    1









[End]


$$ ---   [NOTE]    --------------------------------------------------------------  $$
$$ nucdata   =  1                       $$ nuetron's nuclear data library => 0:Off, 1:On
$$ negs      =  1                       $$ transports of electron, photon, position ( default:-1 )
                                        $$  -1: PHITS's original library ( photon )
                                        $$   0: No Transport
                                        $$  +1: EGS5 Library             ( photon, electron )
$$ emcpf     = 20.0                     $$ upper limit of the detailed photon model
$$ emin(12)  = 0.1     $ ==  1(keV)     $$ upr-limit of transport :: electron (MeV)
$$ emin(13)  = 0.1     $ ==  1(keV)     $$ upr-limit of transport :: positron (MeV)
$$ dmax(12)  = 1000.0                   $$ use of nuclear data ( emin(12) < energy < dmax(12) )
$$ ------------------------------------------------------------------------------  $$
